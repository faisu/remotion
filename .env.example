# Copy this file to `.env.local` for local development.
# Restart the dev server after changing environment variables.

# Vercel Blob Storage (for storing rendered videos and caching sandboxes)
# Create a Blob store at: Vercel Dashboard -> Storage -> Create -> Blob
BLOB_READ_WRITE_TOKEN=your_vercel_blob_read_write_token_here

# Anthropic API key required for /chat (get from https://console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Brave Search API key (optional) — enables web search + real image search for videos
# Get a free key at: https://brave.com/search/api/
BRAVE_SEARCH_API_KEY=your_brave_search_api_key_here
